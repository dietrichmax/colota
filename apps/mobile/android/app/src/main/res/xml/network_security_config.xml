<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Cleartext HTTP is permitted here because Android's network_security_config
        does not support IP-range matching (CIDR), and users need HTTP access to
        self-hosted servers on private networks (10.x.x.x, 192.168.x.x, 172.16-31.x.x).

        Actual enforcement happens at the app level:
          - UrlSafety.isValidProtocol() restricts HTTP to private hosts
          - settingsValidation.isEndpointAllowed() blocks public HTTP endpoints in the UI

        Trust anchors: system only. User-installed device CAs are deliberately
        NOT honored so a malicious or compromised CA on the device can't MITM
        location sync. Self-hosted users with a private CA should import it via
        the mTLS Settings screen -> Trusted Server CA - that path is
        Colota-scoped and backed by Android Keystore.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>