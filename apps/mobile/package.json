{
  "name": "@colota/mobile",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android --mode gmsDebug --appIdSuffix \"\"",
    "android:foss": "react-native run-android --mode fossDebug --appIdSuffix \"\"",
    "android:debug": "cd android && gradlew assembleGmsDebug",
    "android:debug:foss": "cd android && gradlew assembleFossDebug",
    "android:release": "cd android && gradlew assembleGmsRelease",
    "android:release:foss": "cd android && gradlew assembleFossRelease",
    "android:release:all": "cd android && gradlew assembleGmsRelease assembleFossRelease",
    "android:bundle": "cd android && gradlew bundleGmsRelease",
    "clean": "cd android && gradlew clean",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "deploy-release": "adb install android/app/build/outputs/apk/gms/release/app-gms-arm64-v8a-release.apk",
    "deploy-release:foss": "adb install android/app/build/outputs/apk/foss/release/app-foss-arm64-v8a-release.apk",
    "upload:playstore": "cd android && fastlane supply --track production --skip_upload_apk --skip_upload_aab"
  },
  "dependencies": {
    "@colota/shared": "*",
    "@maplibre/maplibre-react-native": "^11.3.0",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "lucide-react-native": "^1.17.0",
    "react": "19.2.7",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "^20.1.3",
    "@react-native-community/cli-platform-ios": "^20.1.3",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.15",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "react-test-renderer": "19.2.7",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
