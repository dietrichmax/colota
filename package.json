{
  "name": "colota",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "version:bump": "py scripts/bump-version.py",
    "sync:screenshots": "py scripts/sync-screenshots.py",
    "generate:icons": "node packages/shared/logo/generate-icons.mjs"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.3"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-test-renderer": "19.2.3"
  },
  "engines": {
    "node": ">=20"
  }
}
